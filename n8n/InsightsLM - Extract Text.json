      "name": "Extract from File"
    },
    {
      "parameters": {
        "jsCode": "// For plain text (.txt/.md) files: decode binary data downloaded by HTTP Request node\n// When responseFormat='file', n8n stores the file in $binary.data as a base64 string\nconst binaryData = $binary?.data;\nif (!binaryData) {\n  return [{ json: { text: '' } }];\n}\n// n8n binary data property: { data (base64 string), mimeType, fileName, fileSize }\nconst text = Buffer.from(binaryData.data, 'base64').toString('utf-8');\nreturn [{ json: { text } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
