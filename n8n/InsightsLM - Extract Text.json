      "name": "Extract from Excel"
    },
    {
      "parameters": {
        "jsCode": "// Convert Excel JSON rows → readable text for RAG\n// extractFromFile xlsx outputs: [{col1: val1, col2: val2, ...}, ...]\nconst items = $input.all();\nconst lines = items.map(item => {\n  return Object.entries(item.json)\n    .filter(([k]) => k !== 'row_number')\n    .map(([k, v]) => `${k}: ${v}`)\n    .join(' | ');\n}).filter(line => line.trim().length > 0);\n\nreturn [{ json: { text: lines.join('\\n') } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        688
      ],
      "id": "8e521a1f-2749-4fc2-a352-012c4245e258",
      "name": "Convert Excel to Text"
